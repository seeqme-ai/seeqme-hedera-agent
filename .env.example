PORT=3100
BASE_URL=

# ─── Hedera network ───────────────────────────────────────────────────────────
# Must be "mainnet" for production. Use "testnet" only for local dev.
HEDERA_NETWORK=mainnet

# ─── Payment recipient ────────────────────────────────────────────────────────
HEDERA_PAYMENT_ACCOUNT_ID=0.0.XXXXXX

# ─── Operator (Hedera Agent Kit — balance queries) ────────────────────────────
HEDERA_OPERATOR_ACCOUNT_ID=0.0.XXXXXX
HEDERA_OPERATOR_PRIVATE_KEY=302e0201...

# ─── x402 facilitator ────────────────────────────────────────────────────────
BLOCKY402_URL=https://blocky402.com

# ─── SeeqMe backend ───────────────────────────────────────────────────────────
SEEQME_BACKEND_URL=https://seeqme.com

# Shared secret — generate with: openssl rand -hex 32
SEEQME_AGENT_SECRET=replace-with-openssl-rand-hex-32
